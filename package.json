{
  "name": "goal-tracker-widget",
  "version": "1.0.0",
  "description": "Финансовый трекер с Obsidian интеграцией",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0"
  },
  "build": {
    "appId": "com.goalswidget.app",
    "productName": "Goals Widget",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}